{
  "name": "perch",
  "version": "0.1.0",
  "description": "Perch - Intelligent screen capture and knowledge management",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && tsc -p src/renderer/tsconfig.json && mkdir -p dist/renderer dist/locales && cp src/renderer/*.html src/renderer/*.css dist/renderer/ && cp src/locales/*.json dist/locales/ && node-gyp rebuild",
    "dev": "concurrently \"tsc -w\" \"electron-reload . && electron .\"",
    "start": "electron .",
    "package": "electron-builder"
  },
  "keywords": [
    "electron",
    "ocr",
    "knowledge",
    "capture"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "node-gyp": "^10.0.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "better-sqlite3": "^12.9.0",
    "d3": "^7.9.0",
    "node-addon-api": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.33.0",
    "uiohook-napi": "^1.5.5"
  },
  "build": {
    "appId": "com.perch.app",
    "productName": "Perch",
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "dist/preload/**/*",
      "dist/locales/**/*",
      "package.json",
      "!dist/mac-arm64/**/*",
      "!dist/Perch-*",
      "!dist/builder-*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "build/Release",
        "to": "build/Release",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "__npminstall_done": false
}
